# --- Bailian / DashScope (阿里云百炼) ---
# Compatible-mode endpoint: chat + vision (OpenAI-compatible, supports enable_thinking/thinking_budget)
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_API_KEY=sk-xxx

# Thinking-capable flagship: persona generation, scene/timeline JSON authoring
AI_MODEL_DEFAULT=qwen3.7-plus
AI_MODEL_VISION=qwen-vl-max
# Cheap/fast tier for low-stakes calls
AI_MODEL_FAST=qwen3.6-flash

# Image generation (qwen-image family) — invoked via `bl` CLI subprocess (see ai/upstream.ts)
AI_MODEL_IMAGE=qwen-image-2.0

# TTS (CosyVoice) — invoked via `bl` CLI subprocess
AI_MODEL_TTS=cosyvoice-v3-flash

# Realtime bidirectional voice (WebSocket relay) — requires BAILIAN_WORKSPACE_ID
AI_MODEL_REALTIME=qwen3.5-omni-plus-realtime
# From `bl workspace list` after `bl auth login --console`. Leave empty to disable the realtime feature.
BAILIAN_WORKSPACE_ID=

# 3D figurine generation (Tripo) — invoked via `bl` CLI subprocess (async task)
AI_MODEL_3D=Tripo-P1.0

PORT=8787

# --- apps/web ---
VITE_API_URL=http://localhost:8787
