{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "bun install",
  "buildCommand": "bun run --cwd apps/web build",
  "outputDirectory": "apps/web/dist",
  "framework": "vite",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 120
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    }
  ]
}
